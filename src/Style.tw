:: StoryStylesheet [stylesheet]

/* 原生 sidebar（左边） */
#ui-bar {
  width: 300px;
}

/* 你的 sidebar（往右挪） */
#sidebar {
  position: fixed;
  left: 300px;   /* 👈 关键：从 ui-bar 右边开始 */
  top: 0;
  width: 250px;
  height: 100vh;
  background: #111;
  color: white;
  padding: 15px;
  border-right: 2px solid #555;
  box-sizing: border-box;
  overflow-y: auto;
}

/* 主内容整体往右 */
#story {
  margin-left: 560px;  /* 300 + 250 */
}

/* passage 再稍微调 */
#passages {
  margin-left: 0;
}