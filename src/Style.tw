
:: StoryStylesheet [stylesheet]

:: StoryStylesheet [stylesheet]

#sidebar {
  display: none;
}

.my-sidebar {
  padding: 10px;
}

.image-area img {
  width: 100%;
  height: auto;
}

.bag-slot {
  border: 1px solid #888;
  padding: 10px;
  margin: 6px;
}

#story,
#ui-bar.stowed ~ #story {
  margin-left: 0 !important;
}

#passages {
  margin-left: 560px !important;
}

.profile-img {
  width: 180px;
}